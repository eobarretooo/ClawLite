# Copy this file to a local path such as .env.docker and point
# CLAWLITE_DOCKER_ENV_FILE at that file when running scripts/docker_setup.sh
# or clawlite validate preflight --docker.
#
# Do not commit real tokens or provider keys.

CLAWLITE_UID=1000
CLAWLITE_GID=1000
CLAWLITE_PIP_EXTRAS=telegram,media,observability,runtime
CLAWLITE_INSTALL_BROWSER=
CLAWLITE_BUS_BACKEND=inprocess
CLAWLITE_BUS_REDIS_URL=redis://redis:6379/0
CLAWLITE_BUS_REDIS_PREFIX=clawlite:bus
