# Copy this file to a local path such as .env.docker and point
# CLAWLITE_DOCKER_ENV_FILE at that file when running scripts/docker_setup.sh
# or clawlite validate preflight --docker.
#
# Do not commit real tokens or provider keys.

CLAWLITE_UID=1000
CLAWLITE_GID=1000
CLAWLITE_PIP_EXTRAS=telegram,media,observability,runtime
CLAWLITE_INSTALL_BROWSER=

# Runtime/provider overrides
CLAWLITE_MODEL=
CLAWLITE_LITELLM_BASE_URL=
CLAWLITE_LITELLM_API_KEY=
CLAWLITE_API_KEY=

# Gateway auth inside the container
CLAWLITE_GATEWAY_AUTH_MODE=
CLAWLITE_GATEWAY_AUTH_TOKEN=
CLAWLITE_GATEWAY_AUTH_ALLOW_LOOPBACK=

# Common provider env vars passed through by docker-compose.yml
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Codex / Gemini auth paths and OAuth-style tokens
CLAWLITE_CODEX_ACCESS_TOKEN=
OPENAI_CODEX_ACCESS_TOKEN=
OPENAI_ACCESS_TOKEN=
CLAWLITE_CODEX_ACCOUNT_ID=
OPENAI_ORG_ID=
CLAWLITE_CODEX_BASE_URL=
CLAWLITE_GEMINI_ACCESS_TOKEN=
GEMINI_ACCESS_TOKEN=
CLAWLITE_GEMINI_ACCOUNT_ID=
GEMINI_ACCOUNT_ID=
CLAWLITE_GEMINI_AUTH_PATH=

# Runtime bus
CLAWLITE_BUS_BACKEND=inprocess
CLAWLITE_BUS_REDIS_URL=redis://redis:6379/0
CLAWLITE_BUS_REDIS_PREFIX=clawlite:bus
